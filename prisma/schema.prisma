
generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  moduleFormat="commonjs"
}

datasource db {
  provider = "postgresql"
}
model User{
  id Int @id @default(autoincrement())
  name String
  email String @unique
  password String
  image Image[]
}
model Image{
  id Int @id @default(autoincrement())
  image String?
  user  User? @relation(fields:[userId], references:[id])
  userId Int?
}